generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Payer {
  father
  mother
}

enum ExpenseSource {
  rakuten
  advance
  personal
}

model Expense {
  id              String        @id @default(uuid()) @db.Uuid
  no              Int           @default(autoincrement())
  householdId     String?       @map("household_id") @db.Uuid
  accountingMonth String        @map("accounting_month") @db.VarChar(7)
  date            DateTime?     @db.Date
  categoryId      String        @map("category_id")
  subCategoryId   String        @map("sub_category_id")
  item            String        @default("")
  description     String        @default("")
  amount          Int
  payer           Payer
  source          ExpenseSource
  reimbursed      Boolean       @default(false)
  beneficiary     String        @default("")
  comment         String        @default("")
  userId          String?       @map("user_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  household       Household?    @relation(fields: [householdId], references: [id])
  category        Category      @relation(fields: [categoryId], references: [id])
  subCategory     SubCategory   @relation(fields: [subCategoryId], references: [id])

  @@index([householdId])
  @@index([accountingMonth])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([payer])
  @@index([source])
  @@map("expenses")
}

model Deposit {
  id          String   @id @default(uuid()) @db.Uuid
  no          Int      @default(autoincrement())
  householdId String?  @map("household_id") @db.Uuid
  date        DateTime @db.Date
  depositor   Payer
  amount      Int
  description String   @default("")
  comment     String   @default("")
  userId      String?  @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  household   Household? @relation(fields: [householdId], references: [id])

  @@index([householdId])
  @@index([date])
  @@index([depositor])
  @@map("deposits")
}

model Category {
  id            String        @id
  householdId   String?       @map("household_id") @db.Uuid
  name          String
  color         String        @default("#64748b") @db.VarChar(16)
  isActive      Boolean       @default(true) @map("is_active")
  sortOrder     Int           @default(0) @map("sort_order")
  userId        String?       @map("user_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  household     Household?    @relation(fields: [householdId], references: [id])
  subCategories SubCategory[]
  expenses      Expense[]

  @@index([householdId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("categories")
}

model SubCategory {
  id         String    @id
  categoryId String    @map("category_id")
  name       String
  isActive   Boolean   @default(true) @map("is_active")
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  category   Category  @relation(fields: [categoryId], references: [id])
  expenses   Expense[]

  @@index([categoryId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("sub_categories")
}

model Household {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @default("FamFi")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  allowedMembers AllowedMember[]
  fixedCosts     FixedCost[]
  expenses       Expense[]
  deposits       Deposit[]
  categories     Category[]

  @@map("households")
}

model AllowedMember {
  id          String    @id @default(uuid()) @db.Uuid
  householdId String    @map("household_id") @db.Uuid
  email       String
  nickname    String
  role        String    @default("member")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  household   Household @relation(fields: [householdId], references: [id])

  @@unique([householdId, email])
  @@index([email])
  @@index([householdId])
  @@map("allowed_members")
}

model FixedCost {
  id            String        @id @default(uuid()) @db.Uuid
  householdId   String        @map("household_id") @db.Uuid
  label         String
  categoryId    String        @map("category_id")
  subCategoryId String        @map("sub_category_id")
  amount        Int           @default(0)
  dueDay        Int           @default(1) @map("due_day")
  payer         Payer
  source        ExpenseSource
  beneficiary   String        @default("")
  description   String        @default("")
  isActive      Boolean       @default(true) @map("is_active")
  createdBy     String?       @map("created_by") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  household     Household     @relation(fields: [householdId], references: [id])

  @@index([householdId])
  @@index([isActive])
  @@map("fixed_costs")
}
